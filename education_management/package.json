{
  "name": "education-management",
  "private": true,
  "workspaces": [
    "packages/*",
    "mobile"
  ],
  "scripts": {
    "prepare": "husky",
    "test:server": "npm run test --workspace=@quran-review/server",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3"
  },
  "lint-staged": {
    "packages/server/src/**/*.ts": [
      "prettier --write",
      "cd packages/server && npx tsc --noEmit"
    ],
    "packages/shared/src/**/*.ts": [
      "prettier --write"
    ],
    "mobile/src/**/*.{ts,tsx}": [
      "prettier --write"
    ],
    "mobile/app/**/*.{ts,tsx}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "agency-agents": "^0.0.1",
    "zustand": "^4.5.7",
    "expo": "~54.0.35",
    "react": "19.1.0",
    "react-native": "0.81.5"
  },
  "version": "1.0.0"
}
