{
  "expo": {
    "name": "مراجعة القرآن",
    "slug": "quran-review",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchitecture": true,
    "scheme": "quran-review",
    "splash": {
