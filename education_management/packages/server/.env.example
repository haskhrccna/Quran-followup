# Required
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/education?schema=public
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Must be at least 32 characters (server refuses to start otherwise).
JWT_SECRET=change-this-to-a-256-bit-secret-minimum-32-characters

# Seed passwords (only used by `prisma db seed`; required in production)
SEED_ADMIN_PASSWORD=
SEED_TEACHER_PASSWORD=
SEED_STUDENT_PASSWORD=

# Server
NODE_ENV=development
PORT=4000

# JWT
JWT_EXPIRES_IN=7d

# Redis (optional — enables queues and caching)
REDIS_URL=redis://localhost:6379
# REDIS_HOST=localhost
# REDIS_PORT=6379

# Email (optional — enables email notifications)
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=noreply@education-app.com

# FCM Push Notifications (optional)
FCM_SERVICE_ACCOUNT_KEY=

# Workers (set to true in production for background jobs)
ENABLE_WORKERS=false

# Client URL (for CORS in production)
CLIENT_URL=
