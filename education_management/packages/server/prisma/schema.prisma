generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  STUDENT
  TEACHER
  ADMIN
  PARENT
}

enum UserStatus {
  PENDING
  APPROVED
  ACTIVE
  BANNED
}

enum ParentLinkStatus {
  PENDING
  APPROVED
  DENIED
}

enum AppointmentStatus {
  REQUESTED
  ACCEPTED
  AMENDED
  REJECTED
  COMPLETED
  CANCELLED
}

enum TeacherChangeStatus {
  PENDING
  APPROVED
  DENIED
}

enum GradeType {
  QUIZ
  ASSIGNMENT
  EXAM
  ORAL
  PARTICIPATION
}

enum MessageType {
  TEXT
  FILE
  SYSTEM
}

enum MemorizationStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETE
}

enum RevisionStatus {
  PENDING
  COMPLETED
  MISSED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

model User {
  id                String     @id @default(uuid())
  email             String     @unique
  passwordHash      String
  role              Role
  firstName         String
  lastName          String
  status            UserStatus @default(PENDING)
  emailVerifiedAt   DateTime?
  deviceToken       String?
  refreshTokenHash  String?
  passwordResetToken  String?
  passwordResetExpiry DateTime?
  passwordChangedAt     DateTime?
  deletedAt             DateTime?
  assignedTeacherId     String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  assignedTeacher        User?                  @relation("StudentTeacherAssignment", fields: [assignedTeacherId], references: [id], onDelete: SetNull)
  assignedStudents       User[]                 @relation("StudentTeacherAssignment")
  appointmentsAsStudent  Appointment[]          @relation("StudentAppointments")
  appointmentsAsTeacher  Appointment[]          @relation("TeacherAppointments")
  gradesGiven            Grade[]                @relation("TeacherGrades")
  gradesReceived         Grade[]                @relation("StudentGrades")
  recordings             Recording[]            @relation("StudentRecordings")
  messagesSent           Message[]              @relation("MessageSender")
  messagesReceived       Message[]              @relation("MessageReceiver")
  reportsGenerated       Report[]               @relation("TeacherReports")
  reportsReceived        Report[]               @relation("StudentReports")
  reviewedRecordings     Recording[]            @relation("ReviewedRecordings")
  memorizationProgresses MemorizationProgress[] @relation("UserMemorizations")
  revisionSchedules      RevisionSchedule[]     @relation("UserRevisions")
  auditLogs              AuditLog[]
  teacherChangeRequestsAsStudent  TeacherChangeRequest[] @relation("StudentChangeRequests")
  teacherChangeRequestsAsTeacher  TeacherChangeRequest[] @relation("TeacherChangeRequests")
  notifications                    Notification[]
  sessionRecordsAsStudent         SessionRecord[] @relation("StudentSessionRecords")
  sessionRecordsAsTeacher         SessionRecord[] @relation("TeacherSessionRecords")
  parentLinksAsParent            ParentLink[]    @relation("ParentLinkParent")
  parentLinksAsStudent            ParentLink[]    @relation("ParentLinkStudent")
  parentLinksDecided              ParentLink[]    @relation("ParentLinkDecider")
  // Phase 5 — Gamification
  streak                          Streak?
  userBadges                      UserBadge[]     @relation("UserBadgeOwner")
  // Phase 6 — Hifz certificates + Halaqa rooms
  certificates                    Certificate[]
  halaqaRoomsAsTeacher            HalaqaRoom[]      @relation("HalaqaRoomTeacher")
  halaqaParticipations            HalaqaParticipant[]

  @@index([email])
  @@index([role, status])
  @@index([refreshTokenHash])
    @@index([deletedAt])
  @@map("users")
}

model Appointment {
  id              String            @id @default(uuid())
  studentId       String
  teacherId       String
  requestedDate   DateTime
  requestedTime   String
  durationMinutes Int               @default(60)
  status          AppointmentStatus @default(REQUESTED)
  approvedAt      DateTime?
  rejectedAt      DateTime?
  amendedNote     String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  student User @relation("StudentAppointments", fields: [studentId], references: [id], onDelete: Cascade)
  teacher User @relation("TeacherAppointments", fields: [teacherId], references: [id], onDelete: Cascade)

  sessionRecord SessionRecord?

  @@index([teacherId, requestedDate, status])
  @@index([studentId])
  @@index([status])
  @@map("appointments")
}

model Grade {
  id        String    @id @default(uuid())
  studentId String
  teacherId String
  surahId   Int?
  grade     String
  type      GradeType
  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  student User   @relation("StudentGrades", fields: [studentId], references: [id], onDelete: Cascade)
  teacher User   @relation("TeacherGrades", fields: [teacherId], references: [id], onDelete: Cascade)
  surah   Surah? @relation(fields: [surahId], references: [id], onDelete: SetNull)

  @@index([studentId])
  @@index([teacherId])
  @@index([surahId])
  @@map("grades")
}

model Recording {
  id              String    @id @default(uuid())
  studentId       String
  url             String
  fileName        String
  fileSizeBytes   Int
  contentType     String
  previewImageUrl String?
  reviewNotes     String?
  approvedAt      DateTime?
  rejectedAt      DateTime?
  reviewedBy      String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  student  User  @relation("StudentRecordings", fields: [studentId], references: [id], onDelete: Cascade)
  reviewer User? @relation("ReviewedRecordings", fields: [reviewedBy], references: [id], onDelete: SetNull)

  @@index([studentId])
  @@index([studentId, createdAt])
  @@index([reviewedBy])
  @@index([createdAt])
  @@map("recordings")
}

model Message {
  id            String      @id @default(uuid())
  senderId      String
  receiverId    String
  type          MessageType @default(TEXT)
  content       String
  attachmentUrl String?
  readAt        DateTime?
  createdAt     DateTime    @default(now())

  sender   User @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("MessageReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([senderId, createdAt])
  @@index([receiverId, createdAt])
  @@index([receiverId, readAt, createdAt])
  @@index([createdAt])
  @@map("messages")
}

model Report {
  id          String   @id @default(uuid())
  teacherId   String
  studentId   String
  pdfUrl      String
  generatedAt DateTime @default(now())
  summary     String

  teacher User @relation("TeacherReports", fields: [teacherId], references: [id], onDelete: Cascade)
  student User @relation("StudentReports", fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([teacherId])
  @@index([generatedAt])
  @@map("reports")
}

model AuditLog {
  id           String   @id @default(uuid())
  userId       String?
  action       String
  resourceType String
  resourceId   String?
  details      Json?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─── Quran Review Models ──────────────────────────────────────────────────────

model Surah {
  id                     Int                    @id @default(autoincrement())
  number                 Int                    @unique // 1-114
  nameAr                 String
  nameEn                 String
  ayahCount              Int
  juz                    Int // Juz number (1-30)
  pages                  Int[]                  @default([])
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  memorizationProgresses MemorizationProgress[]
  revisionSchedules      RevisionSchedule[]
  grades                 Grade[]
  ayahs                  Ayah[]

  @@index([juz])
  @@index([number])
  @@map("surahs")
}

model MemorizationProgress {
  id             String             @id @default(uuid())
  userId         String
  surahId        Int
  status         MemorizationStatus @default(NOT_STARTED)
  memorizedAyahs Int                @default(0)
  lastRecitedAt  DateTime?
  completedAt    DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  user  User  @relation("UserMemorizations", fields: [userId], references: [id], onDelete: Cascade)
  surah Surah @relation(fields: [surahId], references: [id], onDelete: Cascade)

  @@unique([userId, surahId])
  @@index([userId])
  @@index([surahId])
  @@map("memorization_progress")
}

model RevisionSchedule {
  id           String         @id @default(uuid())
  userId       String
  surahId      Int
  scheduledFor DateTime
  status       RevisionStatus @default(PENDING)
  notedAt      DateTime?
  // SM-2 spaced-repetition state (Phase 4).
  interval     Int            @default(1)
  easeFactor   Float          @default(2.5)
  repetitions  Int            @default(0)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  user  User  @relation("UserRevisions", fields: [userId], references: [id], onDelete: Cascade)
  surah Surah @relation(fields: [surahId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([userId, scheduledFor])
  @@index([surahId])
  @@index([scheduledFor, status])
  @@index([userId, status, scheduledFor])
  @@map("revision_schedule")
}

model TeacherChangeRequest {
  id               String              @id @default(cuid())
  studentId        String
  currentTeacherId String?
  reason           String
  status           TeacherChangeStatus @default(PENDING)
  adminNote        String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  student        User  @relation("StudentChangeRequests", fields: [studentId], references: [id], onDelete: Cascade)
  currentTeacher User? @relation("TeacherChangeRequests", fields: [currentTeacherId], references: [id], onDelete: SetNull)

  @@index([studentId])
  @@index([currentTeacherId])
  @@index([status])
  @@map("teacher_change_requests")
}

// ─── Phase 1 — Notification Center ───────────────────────────────────────────

model Notification {
  id        String    @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String
  data      Json?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
  @@index([userId, createdAt])
  @@map("notifications")
}

// ─── Phase 2 — Attendance / Session Records ─────────────────────────────────

model SessionRecord {
  id            String           @id @default(cuid())
  appointmentId String           @unique
  studentId     String
  teacherId     String
  status        AttendanceStatus
  notes         String?
  recordedAt    DateTime         @default(now())

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  student     User        @relation("StudentSessionRecords", fields: [studentId], references: [id], onDelete: Cascade)
  teacher     User        @relation("TeacherSessionRecords", fields: [teacherId], references: [id], onDelete: Cascade)

  @@index([studentId, recordedAt])
  @@index([teacherId, recordedAt])
  @@index([status])
  @@map("session_records")
}

// ─── Phase 3 — Parent / Guardian role + dashboard ───────────────────────────

model ParentLink {
  id         String           @id @default(cuid())
  parentId   String
  studentId  String
  status     ParentLinkStatus @default(PENDING)
  reason     String?
  requestedAt DateTime        @default(now())
  decidedAt  DateTime?
  decidedBy  String?

  parent  User  @relation("ParentLinkParent",  fields: [parentId],  references: [id], onDelete: Cascade)
  student User  @relation("ParentLinkStudent", fields: [studentId], references: [id], onDelete: Cascade)
  decider User? @relation("ParentLinkDecider", fields: [decidedBy], references: [id], onDelete: SetNull)

  @@unique([parentId, studentId])
  @@index([parentId, status])
  @@index([studentId, status])
  @@index([status])
  @@map("parent_links")
}

// ─── Phase 5 — Gamification (streaks, badges, leaderboard) ──────────────────

// Daily-activity streak per student. A "day" is UTC; the rule is
//   same day          → currentStreak unchanged
//   +1 day (consec)   → currentStreak += 1
//   gap of >= 2 days  → currentStreak reset to 1
model Streak {
  userId         String   @id
  currentStreak  Int      @default(0)
  longestStreak  Int      @default(0)
  lastActiveDate DateTime @db.Date

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([currentStreak])
  @@map("streaks")
}

// Catalog of badges. The catalog is seeded once in
// migrations/.../add_gamification/migration.sql and never mutated at runtime.
model Badge {
  id          String      @id @default(cuid())
  code        String      @unique
  name        String
  description String
  iconKey     String
  createdAt   DateTime    @default(now())
  userBadges  UserBadge[] @relation("BadgeAwards")

  @@map("badges")
}

// Idempotent award record: UNIQUE(userId, badgeId) guarantees
// `evaluateMilestones` can run on every activity without producing duplicates.
model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  badgeId   String
  earnedAt  DateTime @default(now())

  user  User  @relation("UserBadgeOwner", fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation("BadgeAwards",     fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@index([userId, earnedAt])
  @@map("user_badges")
}

// Auto-issued when a student's MemorizationProgress reaches COMPLETE for all 114 surahs.
model Certificate {
  id        String   @id @default(uuid())
  studentId String
  pdfUrl    String
  issuedAt  DateTime @default(now())

  student User @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@map("certificates")
}

enum HalaqaStatus {
  WAITING
  LIVE
  ENDED
}

// A live group session room created by a teacher.
model HalaqaRoom {
  id        String       @id @default(uuid())
  teacherId String
  title     String
  status    HalaqaStatus @default(WAITING)
  startedAt DateTime?
  endedAt   DateTime?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  teacher      User                @relation("HalaqaRoomTeacher", fields: [teacherId], references: [id], onDelete: Cascade)
  participants HalaqaParticipant[]

  @@index([teacherId, status])
  @@index([status, createdAt])
  @@map("halaqa_rooms")
}

// Tracks who joined/left a HalaqaRoom (for attendance and signaling).
model HalaqaParticipant {
  id       String    @id @default(uuid())
  roomId   String
  userId   String
  joinedAt DateTime  @default(now())
  leftAt   DateTime?

  room HalaqaRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
  @@index([roomId])
  @@index([userId])
  @@map("halaqa_participants")
}


model Ayah {
  id          Int      @id @default(autoincrement())
  number      Int
  surahId     Int
  page        Int
  juz         Int
  audioUrl    String?
  text        String?
  createdAt   DateTime @default(now())

  surah Surah @relation(fields: [surahId], references: [id], onDelete: Cascade)

  @@unique([surahId, number])
  @@index([surahId])
  @@index([page])
  @@map("ayahs")
}
